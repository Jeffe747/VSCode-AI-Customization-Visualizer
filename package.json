{
  "name": "aivisualizer",
  "displayName": "Copilot AI Customization Visualizer",
  "description": "Visualize and edit Copilot AI customization files.",
  "version": "0.0.21",
  "author": {
    "name": "Jeppe Andreas Jakobsen",
    "url": "https://github.com/Jeffe747"
  },
  "license": "MIT",
  "publisher": "jeffe747",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jeffe747/AI_Customization_Visualizer.git"
  },
  "bugs": {
    "url": "https://github.com/Jeffe747/AI_Customization_Visualizer/issues"
  },
  "homepage": "https://github.com/Jeffe747/AI_Customization_Visualizer#readme",
  "icon": "resources/agent-graph.png",
  "keywords": [
    "copilot",
    "ai",
    "agents",
    "prompts",
    "instructions",
    "skills",
    "visualizer"
  ],
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "aivisualizer.refresh",
        "title": "Refresh Copilot AI Customization Visualizer",
        "icon": "$(refresh)"
      },
      {
        "command": "aivisualizer.popout",
        "title": "Open Copilot AI Customization Visualizer in Window-mode",
        "icon": "$(multiple-windows)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aivisualizer",
          "title": "Copilot AI Customization Visualizer",
          "icon": "resources/agent-graph.svg"
        }
      ]
    },
    "views": {
      "aivisualizer": [
        {
          "id": "aivisualizer.agentVisualizer",
          "name": "Customization Graph",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "aivisualizer.refresh",
          "when": "view == aivisualizer.agentVisualizer",
          "group": "navigation"
        },
        {
          "command": "aivisualizer.popout",
          "when": "view == aivisualizer.agentVisualizer",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "overrides": {
    "diff": "^9.0.0",
    "serialize-javascript": "^7.0.5"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  }
}
